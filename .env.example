# Copy to .env and adjust. Real .env is gitignored.

# Spring 백엔드 API 베이스 (끝에 / 없이)
VITE_API_BASE_URL=http://localhost:8080

# 카카오 OAuth2 로그인 시작 경로 (API 호스트 뒤에 붙는 경로). 비우면 /oauth2/authorization/kakao 사용
# VITE_OAUTH2_KAKAO_AUTHORIZATION_PATH=/oauth2/authorization/kakao

# 위 조합 대신 전체 URL을 한 번에 줄 때(선택). 설정 시 VITE_API_BASE_URL + 경로 조합보다 우선
# VITE_KAKAO_OAUTH_AUTHORIZATION_URL=http://localhost:8080/oauth2/authorization/kakao
