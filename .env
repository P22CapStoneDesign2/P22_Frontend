VITE_API_BASE_URL=http://localhost:8080

# 프론트 공개 URL(비밀번호 찾기 메일 링크 — 백엔드로 전달). vite dev 포트와 맞출 것 (기본 예: 5174)
# VITE_APP_PUBLIC_URL=http://localhost:5174

# 선택: 카카오 OAuth 경로만 바꿀 때 (기본 /oauth2/authorization/kakao)
# VITE_OAUTH2_KAKAO_AUTHORIZATION_PATH=/oauth2/authorization/kakao

# 선택: 카카오 로그인 전체 URL을 한 줄로 줄 때
# VITE_KAKAO_OAUTH_AUTHORIZATION_URL=http://localhost:8080/oauth2/authorization/kakao
